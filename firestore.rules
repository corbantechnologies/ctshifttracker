rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate (Deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Auth-based role check (Use sparingly in list)
    function isHRAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'HR Admin';
    }

    function isManager() {
      return isSignedIn() && get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'Manager';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 2. Validation Blueprints
    function isValidEmployee(data) {
      return data.uid is string && 
             data.uid == request.auth.uid &&
             data.email is string && 
             data.email.size() > 0 &&
             data.name is string && 
             data.name.size() > 0 &&
             data.role in ['HR Admin', 'Manager', 'Employee'] &&
             data.isActive is bool &&
             data.otEnabled is bool &&
             data.keys().hasAll(['uid', 'email', 'name', 'role', 'isActive', 'otEnabled', 'createdAt', 'department']) &&
             data.keys().size() == 8;
    }

    function isValidShift(data) {
      return data.name is string && data.name.size() > 0 &&
             data.startTime is string && data.startTime.matches('^[0-9]{2}:[0-9]{2}$') &&
             data.endTime is string && data.endTime.matches('^[0-9]{2}:[0-9]{2}$') &&
             data.daysOfWeek is list &&
             data.keys().size() >= 4;
    }

    function isValidAttendance(data) {
      return data.employeeUid is string && 
             data.employeeUid == request.auth.uid &&
             data.date is string &&
             data.clockIn is string &&
             data.status in ['Present', 'Late', 'Absent', 'Early Leave', 'On Break'] &&
             data.keys().hasAll(['employeeUid', 'shiftId', 'date', 'clockIn', 'status']) &&
             data.keys().size() <= 9; // Allowing totalMinutes, clockOut, overtimeMinutes, approved later
    }

    // --- Collections ---

    match /employees/{uid} {
      // HR can read all, Staff can read all (to see colleagues)
      allow read: if isSignedIn();
      
      // Create own profile
      allow create: if isSignedIn() && isValidEmployee(incoming()) && uid == request.auth.uid;
      
      // Update: HR can update any, Others can only update limited fields
      allow update: if isSignedIn() && (
        isHRAdmin() || 
        (isOwner(uid) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department']))
      );
    }

    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow write: if isHRAdmin() && isValidShift(incoming());
    }

    match /attendance/{attendanceId} {
      allow list: if isSignedIn(); 
      allow get: if isSignedIn();

      allow create: if isSignedIn() && incoming().employeeUid == request.auth.uid;
      
      allow update: if isSignedIn() && (
        (isOwner(resource.data.employeeUid) && incoming().diff(resource.data).affectedKeys().hasOnly(['clockOut', 'totalMinutes', 'overtimeMinutes', 'status'])) ||
        isHRAdmin() ||
        (isManager() && incoming().diff(resource.data).affectedKeys().hasOnly(['approved']))
      );
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isHRAdmin();
    }

    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow write: if isHRAdmin();
    }
  }
}
